ALTER   PROCEDURE [dbo].[sp_Retirar]
    @NumeroCuenta CHAR(20),
    @IdCliente INT,
    @Monto DECIMAL(18,2),
    @NumeroTarjeta CHAR(20) = NULL,
    @PIN CHAR(4) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;
    SET TRANSACTION ISOLATION LEVEL SERIALIZABLE

    DECLARE @IdMovimientoNuevo INT
    DECLARE @SaldoActual DECIMAL(18,2)
    DECLARE @FechaHora DATETIME = GETDATE()

    BEGIN TRY
        BEGIN TRANSACTION

        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        -- Validación monto
        IF @Monto <= 0
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, FechaDocumento,
                NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 2, NULL,
                @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
                ABS(@Monto), @FechaHora
            )

            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'I')
            SELECT 'Monto no valido o insuficiente'
            COMMIT
            RETURN
        END

        -- Obtener saldo con bloqueo
        SELECT @SaldoActual = Saldo
        FROM Cuenta WITH (UPDLOCK, HOLDLOCK)
        WHERE NumeroCuenta = @NumeroCuenta
          AND IdCliente = @IdCliente
          AND Estado = 'A'

        IF @SaldoActual IS NULL
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, FechaDocumento,
                NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 2, NULL,
                @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
                ABS(@Monto), @FechaHora
            )

            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
            SELECT 'Cuenta no encontrada o no activa'
            COMMIT
            RETURN
        END

        -- Validación con tarjeta
        IF @NumeroTarjeta IS NOT NULL
        BEGIN
            IF NOT EXISTS (
                SELECT 1
                FROM Tarjeta
                WHERE NumeroTarjeta = @NumeroTarjeta
                  AND NumeroCuenta = @NumeroCuenta
                  AND IdCliente = @IdCliente
                  AND Estado = 'A'
            )
            BEGIN
                INSERT INTO MovimientoCuenta (
                    IdMovimiento, IdTipoMovimiento, FechaDocumento,
                    NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                    Monto, FechaHora
                )
                VALUES (
                    @IdMovimientoNuevo, 2, NULL,
                    @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
                    ABS(@Monto), @FechaHora
                )

                INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
                VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
                SELECT 'Tarjeta no valida para esta cuenta'
                COMMIT
                RETURN
            END

            IF NOT EXISTS (
                SELECT 1
                FROM Tarjeta
                WHERE NumeroTarjeta = @NumeroTarjeta
                  AND PIN = @PIN
            )
            BEGIN
                INSERT INTO MovimientoCuenta (
                    IdMovimiento, IdTipoMovimiento, FechaDocumento,
                    NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                    Monto, FechaHora
                )
                VALUES (
                    @IdMovimientoNuevo, 2, NULL,
                    @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
                    ABS(@Monto), @FechaHora
                )

                INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
                VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
                SELECT 'PIN incorrecto para la tarjeta o no existe'
                COMMIT
                RETURN
            END
        END

        -- Validación saldo
        IF @SaldoActual < @Monto
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, FechaDocumento,
                NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 2, NULL,
                @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
                ABS(@Monto), @FechaHora
            )

            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'I')
            SELECT 'Saldo insuficiente para retiro'
            COMMIT
            RETURN
        END

        -- Movimiento válido
        INSERT INTO MovimientoCuenta (
            IdMovimiento, IdTipoMovimiento, FechaDocumento,
            NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
            Monto, FechaHora
        )
        VALUES (
            @IdMovimientoNuevo, 2, NULL,
            @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
            @Monto, @FechaHora
        )

        UPDATE Cuenta
        SET Saldo = Saldo - @Monto
        WHERE NumeroCuenta = @NumeroCuenta
          AND IdCliente = @IdCliente

        INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
        VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'E')

        COMMIT

        SELECT 
            @IdMovimientoNuevo AS IdMovimiento,
            'RETIRO' AS TipoOperacion,
            @SaldoActual AS SaldoAnterior,
            (@SaldoActual - @Monto) AS SaldoNuevo,
            @Monto AS Monto,
            @FechaHora AS FechaHora

    END TRY
    BEGIN CATCH
        IF XACT_STATE() <> 0
            ROLLBACK

        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        INSERT INTO MovimientoCuenta (
            IdMovimiento, IdTipoMovimiento, FechaDocumento,
            NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
            Monto, FechaHora
        )
        VALUES (
            @IdMovimientoNuevo, 2, NULL,
            @NumeroCuenta, @IdCliente, @NumeroTarjeta, NULL,
            ABS(@Monto), GETDATE()
        )

        INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
        VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
    END CATCH
END