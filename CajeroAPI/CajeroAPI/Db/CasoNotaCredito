ALTER   PROCEDURE [dbo].[sp_NotaCredito]
    @NumeroCuenta CHAR(20),
    @IdCliente INT,
    @Monto DECIMAL(18,2),
    @NumeroTarjeta CHAR(20),
    @IdPersona INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;
    SET TRANSACTION ISOLATION LEVEL SERIALIZABLE

    DECLARE @IdMovimientoNuevo INT
    DECLARE @SaldoActual DECIMAL(18,2)
    DECLARE @FechaHora DATETIME = GETDATE()

    BEGIN TRY
        BEGIN TRANSACTION

        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        IF @Monto <= 0
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento,
                NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 3,
                @NumeroCuenta, @IdCliente, @NumeroTarjeta, @IdPersona,
                ABS(@Monto), @FechaHora
            )

            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'I')

            SELECT 'Monto inválido para nota de crédito.' AS Resultado
            COMMIT
            RETURN
        END

        SELECT @SaldoActual = Saldo
        FROM Cuenta WITH (UPDLOCK, HOLDLOCK)
        WHERE NumeroCuenta = @NumeroCuenta
          AND IdCliente = @IdCliente
          AND Estado = 'A'

        IF @SaldoActual IS NULL
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento,
                NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
                Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 3,
                @NumeroCuenta, @IdCliente, @NumeroTarjeta, @IdPersona,
                ABS(@Monto), @FechaHora
            )

            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')

            SELECT 'Cuenta no válida o inactiva.' AS Resultado
            COMMIT
            RETURN
        END

        INSERT INTO MovimientoCuenta (
            IdMovimiento, IdTipoMovimiento,
            NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
            Monto, FechaHora
        )
        VALUES (
            @IdMovimientoNuevo, 3,
            @NumeroCuenta, @IdCliente, @NumeroTarjeta, @IdPersona,
            @Monto, @FechaHora
        )

        UPDATE Cuenta
        SET Saldo = Saldo + @Monto
        WHERE NumeroCuenta = @NumeroCuenta
          AND IdCliente = @IdCliente

        INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
        VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'E')

        COMMIT

        SELECT 
            @IdMovimientoNuevo AS IdMovimiento,
            'CRÉDITO' AS TipoOperacion,
            @SaldoActual AS SaldoAnterior,
            (@SaldoActual + @Monto) AS SaldoNuevo,
            @Monto AS Monto,
            @FechaHora AS FechaHora

    END TRY
    BEGIN CATCH
        IF XACT_STATE() <> 0
            ROLLBACK

        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        INSERT INTO MovimientoCuenta (
            IdMovimiento, IdTipoMovimiento,
            NumeroCuenta, IdCliente, NumeroTarjeta, IdPersona,
            Monto, FechaHora
        )
        VALUES (
            @IdMovimientoNuevo, 3,
            @NumeroCuenta, @IdCliente, @NumeroTarjeta, @IdPersona,
            ABS(@Monto), @FechaHora
        )

        INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
        VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')

        SELECT 'Error al procesar la nota de crédito: ' + ERROR_MESSAGE() AS Resultado
    END CATCH
END