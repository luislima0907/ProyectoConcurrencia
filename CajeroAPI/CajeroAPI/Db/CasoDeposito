ALTER   PROCEDURE [dbo].[sp_Depositar]
    @NumeroCuenta CHAR(20),
    @IdCliente INT,
    @Monto DECIMAL(18,2),
    @IdPersonaQueDeposita INT = NULL 
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    SET TRANSACTION ISOLATION LEVEL SERIALIZABLE

    DECLARE @IdMovimientoNuevo INT

    BEGIN TRY
        BEGIN TRANSACTION

        -- Generar ID seguro
        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        -- Validación de monto
        IF @Monto <= 0
        BEGIN
            -- Insertar movimiento exitoso
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, NumeroCuenta, IdCliente, 
                IdPersona, Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 1, @NumeroCuenta, @IdCliente, 
                @IdPersonaQueDeposita, ABS(@Monto), GETDATE()
            )
            -- Bitácora error
            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'I')
            SELECT 'Monto inválido, se registró el intento de depósito con monto corregido a positivo pero no se realizaron cambios en la cuenta.' AS Resultado
            COMMIT
            RETURN
        END
            --THROW 50004, 'El monto debe ser mayor a cero.', 1;

        -- Bloqueo de la cuenta (clave para concurrencia)
        IF NOT EXISTS (
            SELECT 1 
            FROM Cuenta WITH (UPDLOCK, HOLDLOCK)
            WHERE NumeroCuenta = @NumeroCuenta 
              AND IdCliente = @IdCliente 
              AND Estado = 'A'
        )
        BEGIN
            -- Insertar movimiento exitoso
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, NumeroCuenta, IdCliente, 
                IdPersona, Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 1, @NumeroCuenta, @IdCliente, 
                @IdPersonaQueDeposita, ABS(@Monto), GETDATE()
            )
             -- Bitácora error
            INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
            SELECT 'Cuenta no válida o inactiva, se registró el intento de depósito pero no se realizaron cambios en la cuenta.' AS Resultado
            COMMIT
            RETURN
        END
            --THROW 50005, 'Cuenta no válida o inactiva.', 1;

        -- Insertar movimiento exitoso
        INSERT INTO MovimientoCuenta (
            IdMovimiento, IdTipoMovimiento, NumeroCuenta, IdCliente, 
            IdPersona, Monto, FechaHora
        )
        VALUES (
            @IdMovimientoNuevo, 1, @NumeroCuenta, @IdCliente, 
            @IdPersonaQueDeposita, @Monto, GETDATE()
        )

        -- Actualizar saldo
        UPDATE Cuenta
        SET Saldo = Saldo + @Monto
        WHERE NumeroCuenta = @NumeroCuenta 
          AND IdCliente = @IdCliente

        -- Bitácora éxito
        INSERT INTO BitacoraCuenta (IdBitacora, IdMovimiento, Estado)
        VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'E')

        COMMIT

        SELECT 'Depósito realizado con éxito' AS Resultado

    END TRY
    BEGIN CATCH
        IF XACT_STATE() <> 0
            ROLLBACK

        -- Generar ID seguro
        SET @IdMovimientoNuevo = NEXT VALUE FOR SeqMovimiento

        IF @IdMovimientoNuevo IS NOT NULL
        BEGIN
            INSERT INTO MovimientoCuenta (
                IdMovimiento, IdTipoMovimiento, NumeroCuenta, IdCliente, 
                IdPersona, Monto, FechaHora
            )
            VALUES (
                @IdMovimientoNuevo, 1, @NumeroCuenta, @IdCliente, 
                @IdPersonaQueDeposita, ABS(@Monto), GETDATE()
            )

            INSERT INTO BitacoraCuenta (IdBitacora,IdMovimiento, Estado)
            VALUES (@IdMovimientoNuevo, @IdMovimientoNuevo, 'X')
        END
        SELECT 'Error: ' + ERROR_MESSAGE() AS Resultado
    END CATCH
END
